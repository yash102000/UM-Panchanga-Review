# Backend configuration
HOST=0.0.0.0
PORT=5000
USE_HTTPS=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# Database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=panchanga_db
DB_CHARSET=utf8mb4
DB_CONNECT_TIMEOUT=5

